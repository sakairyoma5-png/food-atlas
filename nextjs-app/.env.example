# =============================================================
# Food Atlas - 環境変数設定例
# Vercelへのデプロイに必要な変数をすべて設定してください
# =============================================================

# ----- Supabase -----------------------------------------------
# supabase.com でプロジェクトを作成して取得
# Settings > API から確認できます
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Database -----------------------------------------------
# Supabase Dashboard > Settings > Database > Connection pooling
# "Transaction" モードのURLを使用 (ポート 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ----- Gemini AI ----------------------------------------------
# Google AI Studio (aistudio.google.com) でAPIキーを無料取得
# ※ 無料枠あり。Gemini 2.0 Flash は高速・低コスト
GEMINI_API_KEY=AIza...

# モデル名 (省略時: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ----- Site URL -----------------------------------------------
# VercelのデプロイURL（カスタムドメイン取得後はそちらに変更）
# robots.txt と OGP タグに使用されます
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
