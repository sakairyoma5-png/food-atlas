# =============================================================
# Food Atlas - 環境変数設定例
# Vercelへのデプロイに必要な変数をすべて設定してください
# =============================================================

# ----- Supabase -----------------------------------------------
# supabase.com でプロジェクトを作成して取得
# Settings > API から確認できます
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Database -----------------------------------------------
# Supabase Dashboard > Settings > Database > Connection pooling
# "Transaction" モードのURLを使用 (ポート 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# ----- OpenAI -------------------------------------------------
# platform.openai.com でAPIキーを取得
# ※ Replitで開発する場合は Replit AI Integration が自動設定するため不要
# ※ Vercel本番環境では必須
OPENAI_API_KEY=sk-...

# モデル名 (省略時: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# ----- Site URL -----------------------------------------------
# VercelのデプロイURL（カスタムドメイン取得後はそちらに変更）
# robots.txt と OGP タグに使用されます
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
